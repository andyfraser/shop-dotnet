@{
    Layout = "_AdminLayout";
    var stats = ViewData["Stats"];
    dynamic s = stats!;
    var recentOrders = ViewData["RecentOrders"] as List<Order> ?? new();
    var lowStock = ViewData["LowStock"] as List<Product> ?? new();
    var currencySymbol = ViewData["CurrencySymbol"] as string ?? "£";
}

<div class="admin-topbar">
  <h1>Dashboard</h1>
  <div class="actions">
    <a href="/admin/products/new" class="btn btn-primary">+ Add Product</a>
  </div>
</div>

<div class="content">
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-val">@s.products</div>
      <div class="stat-label">Active Products</div>
    </div>
    <div class="stat-card">
      <div class="stat-val">@s.customers</div>
      <div class="stat-label">Customers</div>
    </div>
    <div class="stat-card">
      <div class="stat-val">@s.orders</div>
      <div class="stat-label">Total Orders</div>
    </div>
    <div class="stat-card">
      <div class="stat-val">@currencySymbol@(((decimal)s.revenue).ToString("N0"))</div>
      <div class="stat-label">Revenue</div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 300px;gap:1.5rem;align-items:start;">
    <div>
      <div class="page-actions" style="margin-bottom:1rem;">
        <strong style="font-size:.9rem;">Recent Orders</strong>
        <a href="/admin/orders" class="btn btn-outline btn-sm">View All</a>
      </div>
      <table class="data-table">
        <thead>
          <tr>
            <th>Order #</th><th>Customer</th><th>Total</th><th>Status</th><th>Date</th>
          </tr>
        </thead>
        <tbody>
          @if (recentOrders.Any())
          {
            @foreach (var o in recentOrders)
            {
              <tr>
                <td><a href="/admin/orders/detail?id=@o.Id">#@V.PadOrder(o.Id)</a></td>
                <td>@(o.UserName ?? "Guest")</td>
                <td><strong>@V.Money(ViewData["CurrencySymbol"] as string, o.Total)</strong></td>
                <td><span class="badge @V.StatusBadge(o.Status)">@System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(o.Status)</span></td>
                <td>@(DateTime.TryParse(o.CreatedAt, out var d) ? d.ToString("dd MMM") : "")</td>
              </tr>
            }
          }
          else
          {
            <tr><td colspan="5" style="text-align:center;padding:1.5rem;color:var(--ink-2);">No orders yet</td></tr>
          }
        </tbody>
      </table>
    </div>

    <div>
      <div class="page-actions" style="margin-bottom:1rem;">
        <strong style="font-size:.9rem;">Low Stock</strong>
      </div>
      <div class="card" style="padding:0;overflow:hidden;">
        @if (lowStock.Any())
        {
          @foreach (var p in lowStock)
          {
            <div style="display:flex;justify-content:space-between;align-items:center;padding:.75rem 1rem;border-bottom:1px solid var(--line);">
              <div style="font-size:.85rem;font-weight:500;flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                @p.Name
              </div>
              <span class="badge @(p.Stock == 0 ? "badge-danger" : "badge-warning")">@p.Stock left</span>
            </div>
          }
        }
        else
        {
          <div style="padding:1.5rem;text-align:center;color:var(--ink-2);font-size:.85rem;">
            All products well stocked ✓
          </div>
        }
      </div>
    </div>
  </div>
</div>

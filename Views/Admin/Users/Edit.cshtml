@{
    Layout = "_AdminLayout";
    var isNew = (bool)(ViewData["IsNew"] ?? true);
    var userId = (int)(ViewData["UserId"] ?? 0);
    var user = ViewData["User"] as User ?? new();
    var passwordMinLen = (int)(ViewData["PasswordMinLen"] ?? 6);
    var errors = ViewData["Errors"] as IEnumerable<string> ?? Array.Empty<string>();
    var csrfToken = ViewData["CsrfToken"] as string ?? "";
}

<div class="admin-topbar">
  <h1>@(isNew ? "Add User" : $"Edit: {user.Name}")</h1>
  <div class="actions">
    <a href="/admin/users" class="btn btn-outline">← Back</a>
  </div>
</div>

<div class="content">
  @if (errors.Any())
  {
    <div class="alert alert-error">
      @foreach (var e in errors) { <div>@e</div> }
    </div>
  }

  <div class="card" style="max-width:480px;">
    <form method="POST" action="/admin/users">
      <input type="hidden" name="csrf_token" value="@csrfToken">
      @if (userId > 0)
      {
        <input type="hidden" name="id" value="@userId">
      }

      <div class="form-group">
        <label>Full Name *</label>
        <input type="text" name="name" class="form-control" value="@user.Name" required autofocus>
      </div>

      <div class="form-group">
        <label>Email Address *</label>
        <input type="email" name="email" class="form-control" value="@user.Email" required>
      </div>

      <div class="form-group">
        <label>Role</label>
        <select name="role" class="form-control">
          <option value="customer" @(user.Role == "customer" ? "selected" : "")>Customer</option>
          <option value="admin"    @(user.Role == "admin"    ? "selected" : "")>Admin</option>
        </select>
      </div>

      <div class="form-group">
        <label>Shipping Address</label>
        <textarea name="address" class="form-control" rows="3"
                  placeholder="Customer's default shipping address">@(user.Address ?? "")</textarea>
      </div>

      <div class="form-group">
        <label>Password @(userId > 0 ? "(leave blank to keep current)" : "*")</label>
        <input type="password" name="password" class="form-control"
               @(isNew ? "required" : "") minlength="@passwordMinLen">
      </div>

      <div style="display:flex;gap:.75rem;margin-top:.5rem;">
        <button type="submit" name="save" class="btn btn-primary">
          @(isNew ? "Create User" : "Save Changes")
        </button>
        <a href="/admin/users" class="btn btn-outline">Cancel</a>
      </div>
    </form>
  </div>
</div>

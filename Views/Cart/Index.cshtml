@{
    Layout = "_Layout";
    var items = ViewData["Items"] as List<CartItem> ?? new();
    var total = (decimal)(ViewData["Total"] ?? 0m);
    var flashSuccess = ViewData["FlashSuccess"] as string;
    var csrfToken = ViewData["CsrfToken"] as string ?? "";
}
<div class="container">
  <h1 class="page-title">Shopping Cart</h1>

  @if (!string.IsNullOrEmpty(flashSuccess))
  {
    <div class="alert alert-success">@flashSuccess</div>
  }

  @if (!items.Any())
  {
    <div class="empty-state">
      <div class="icon">🛒</div>
      <h3>Your cart is empty</h3>
      <p style="margin-bottom:1.5rem;">Add some products to get started.</p>
      <a href="/" class="btn btn-primary">Browse Products</a>
    </div>
  }
  else
  {
    <div class="two-col">
      <div>
        <div class="card" style="padding:0;overflow:hidden;">
          <form method="POST" action="/cart" id="cart-form">
            <input type="hidden" name="csrf_token" value="@csrfToken">
            <table class="cart-table">
              <thead>
                <tr>
                  <th colspan="2">Product</th>
                  <th>Price</th>
                  <th>Qty</th>
                  <th>Subtotal</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                @foreach (var item in items)
                {
                  <tr data-item-id="@item.Id">
                    <td style="width:80px;">
                      <img src="@V.ImgSrc(item.Image)" alt="@item.Name" class="cart-thumb"
                           onerror="this.onerror=null;this.src='/images/placeholder.svg'">
                    </td>
                    <td>
                      <a href="/product/@item.Slug" class="cart-product-name">@item.Name</a>
                    </td>
                    <td>@V.Money(ViewData["CurrencySymbol"] as string, item.Price)</td>
                    <td>
                      <input type="number" name="qty[@item.Id]" value="@item.Qty" min="0"
                             max="@item.Stock" class="form-control qty-ctrl">
                    </td>
                    <td class="item-subtotal" data-item-id="@item.Id"><strong>@V.Money(ViewData["CurrencySymbol"] as string, item.Subtotal)</strong></td>
                    <td>
                      <button type="submit" name="remove" value="@item.Id" class="btn btn-outline btn-sm"
                              style="padding:.3rem .7rem;color:var(--accent)">✕</button>
                    </td>
                  </tr>
                }
              </tbody>
            </table>
            <div style="padding:1rem;border-top:1px solid var(--line);">
              <button type="submit" name="update" class="btn btn-outline btn-sm">Update Cart</button>
            </div>
          </form>
        </div>
      </div>

      <div class="order-summary">
        <div class="card">
          <h2 style="font-family:var(--font-display);font-size:1.2rem;margin-bottom:1rem;">Order Summary</h2>
          <div style="display:flex;justify-content:space-between;padding:.5rem 0;border-bottom:1px solid var(--line);margin-bottom:.5rem;">
            <span>Subtotal</span><strong>@V.Money(ViewData["CurrencySymbol"] as string, total)</strong>
          </div>
          <div style="display:flex;justify-content:space-between;padding:.5rem 0;border-bottom:1px solid var(--line);margin-bottom:.5rem;">
            <span>Shipping</span><span style="color:var(--accent)">Free</span>
          </div>
          <div style="display:flex;justify-content:space-between;padding:.75rem 0;font-size:1.2rem;font-weight:700;margin-bottom:1.2rem;">
            <span>Total</span><span id="cart-total" style="color:var(--accent-2)">@V.Money(ViewData["CurrencySymbol"] as string, total)</span>
          </div>
          <a href="/checkout" class="btn btn-primary" style="width:100%;justify-content:center;">
            Proceed to Checkout
          </a>
          <a href="/" class="btn btn-outline btn-sm"
             style="width:100%;justify-content:center;margin-top:.75rem;">
            Continue Shopping
          </a>
        </div>
      </div>
    </div>
  }
</div>

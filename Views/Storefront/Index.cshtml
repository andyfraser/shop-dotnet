@{
    Layout = "_Layout";
    var navTree = ViewData["NavTree"] as List<Category> ?? new();
    var featured = ViewData["FeaturedProducts"] as List<Product> ?? new();
}

<div class="hero">
  <div class="hero-inner">
    <h1>Quality goods,<br>curated for you.</h1>
    <p>Browse our thoughtfully selected collection of electronics, clothing, and more.</p>
    <a href="/" class="btn btn-primary" style="font-size:1rem;padding:.8rem 2rem;">
      Shop All Products
    </a>
  </div>
</div>

<div class="container">

  <section class="section">
    <h2 class="section-title">Shop by Category</h2>
    <div class="cat-grid">
      @foreach (var cat in navTree)
      {
        <a href="/category/@cat.Slug" class="cat-card">
          <div class="cat-icon">@(string.IsNullOrEmpty(cat.Icon) ? "📦" : cat.Icon)</div>
          @cat.Name
          @if (cat.Children.Any())
          {
            <div class="cat-sub">@cat.Children.Count subcategories</div>
          }
        </a>
      }
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">Featured Products</h2>
    <div class="product-grid">
      @foreach (var p in featured)
      {
        <a href="/product/@p.Slug" class="product-card">
          <div class="img-wrap">
            @if (p.Featured)
            {
              <span class="product-badge badge-featured">Featured</span>
            }
            else if (V.IsNew(p.CreatedAt))
            {
              <span class="product-badge badge-new">New</span>
            }
            <img src="@V.ImgSrc(p.Image)" alt="@p.Name" loading="lazy"
                 onerror="this.onerror=null;this.src='/images/placeholder.svg'">
          </div>
          <div class="card-body">
            <div class="card-cat">@(p.CatName ?? "Uncategorised")</div>
            <div class="card-name">@p.Name</div>
            <div class="card-price">@V.Money(ViewData["CurrencySymbol"] as string, p.Price)</div>
            <div class="card-actions">
              <span class="btn btn-primary btn-sm">View Product</span>
            </div>
          </div>
        </a>
      }
    </div>
  </section>

</div>
